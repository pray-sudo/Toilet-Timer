<view class="empty-state">
  <view class="empty-state__icon">{{icon}}</view>
  <view class="empty-state__title">{{title}}</view>
  <view wx:if="{{desc}}" class="empty-state__desc">{{desc}}</view>
  <button
    wx:if="{{buttonText}}"
    class="empty-state__btn"
    bindtap="handleButtonTap"
  >
    {{buttonText}}
  </button>
</view>
