.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-state__icon {
  font-size: 80rpx;
  line-height: 1;
  margin-bottom: 24rpx;
}

.empty-state__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #263238;
}

.empty-state__desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
  max-width: 520rpx;
}

.empty-state__btn {
  margin-top: 32rpx;
  padding: 0 48rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: #58b947;
  color: #ffffff;
  font-size: 28rpx;
}

.empty-state__btn::after {
  border: none;
}
