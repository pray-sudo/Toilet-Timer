.progress-timeline {
  padding: 8rpx 0 0;
}

.progress-timeline__track {
  position: relative;
  height: 8rpx;
  border-radius: 999rpx;
  background: #e5e7eb;
  margin: 0 20rpx;
}

.progress-timeline__fill {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #58b947 0%, #f59e0b 70%, #e5484d 100%);
  transition: width 0.3s ease;
}

.progress-timeline__node {
  position: absolute;
  top: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: -12rpx;
  margin-top: -12rpx;
}

.progress-timeline__dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 4rpx solid #d1d5db;
  box-sizing: border-box;
}

.progress-timeline__node--active .progress-timeline__dot {
  border-color: #58b947;
  background: #58b947;
}

.progress-timeline__node:nth-child(3).progress-timeline__node--active .progress-timeline__dot {
  border-color: #f59e0b;
  background: #f59e0b;
}

.progress-timeline__node:nth-child(4).progress-timeline__node--active .progress-timeline__dot {
  border-color: #e5484d;
  background: #e5484d;
}

.progress-timeline__label {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #263238;
  font-weight: 600;
  white-space: nowrap;
}

.progress-timeline__desc {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #9ca3af;
  white-space: nowrap;
}

.progress-timeline__node--active .progress-timeline__label {
  color: #3d8b32;
}

.progress-timeline__node:nth-child(3).progress-timeline__node--active .progress-timeline__label {
  color: #d97706;
}

.progress-timeline__node:nth-child(4).progress-timeline__node--active .progress-timeline__label {
  color: #dc2626;
}
