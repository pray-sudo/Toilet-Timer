.evaluation-card {
  display: flex;
  align-items: flex-start;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.evaluation-card--green {
  background: linear-gradient(135deg, #f0fbe9 0%, #ffffff 100%);
}

.evaluation-card--orange {
  background: linear-gradient(135deg, #fff7e6 0%, #ffffff 100%);
}

.evaluation-card--red {
  background: linear-gradient(135deg, #ffecec 0%, #ffffff 100%);
}

.evaluation-card--gray {
  background: linear-gradient(135deg, #f3f4f6 0%, #ffffff 100%);
}

.evaluation-card__icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  line-height: 1;
}

.evaluation-card__title {
  font-size: 30rpx;
  font-weight: 700;
  color: #263238;
}

.evaluation-card__desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
}
