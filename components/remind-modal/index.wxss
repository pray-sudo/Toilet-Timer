.remind-modal {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
}

.remind-modal__mask {
  position: absolute;
  inset: 0;
  background: rgba(38, 50, 56, 0.45);
}

.remind-modal__panel {
  position: relative;
  width: 100%;
  max-width: 620rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 48rpx 36rpx 36rpx;
  box-shadow: 0 16rpx 48rpx rgba(38, 50, 56, 0.16);
}

.remind-modal__panel--mild {
  border-top: 8rpx solid #58b947;
}

.remind-modal__panel--warning {
  border-top: 8rpx solid #f59e0b;
}

.remind-modal__panel--risk {
  border-top: 8rpx solid #e5484d;
}

.remind-modal__icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  margin: 0 auto 24rpx;
}

.remind-modal__icon--mild {
  background: #eaf7e8;
  color: #58b947;
}

.remind-modal__icon--warning {
  background: #fff7e6;
  color: #f59e0b;
}

.remind-modal__icon--risk {
  background: #ffecec;
  color: #e5484d;
}

.remind-modal__title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #263238;
}

.remind-modal__content {
  margin-top: 16rpx;
  text-align: center;
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.6;
}

.remind-modal__actions {
  margin-top: 36rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.remind-modal__btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.remind-modal__btn::after {
  border: none;
}

.remind-modal__btn--primary {
  color: #ffffff;
}

.remind-modal__btn--mild {
  background: #58b947;
}

.remind-modal__btn--warning {
  background: #f59e0b;
}

.remind-modal__btn--risk {
  background: #e5484d;
}

.remind-modal__btn--secondary {
  background: #f3f4f6;
  color: #6b7280;
}
