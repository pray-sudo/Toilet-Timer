.date-switcher {
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}

.date-switcher__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.date-switcher__btn {
  padding: 12rpx 16rpx;
  font-size: 24rpx;
  color: #58b947;
  white-space: nowrap;
}

.date-switcher__current {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #263238;
}

.date-switcher__back {
  margin-top: 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: #58b947;
}
