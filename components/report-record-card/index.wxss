.report-record-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.report-record-card__main {
  flex: 1;
  min-width: 0;
}

.report-record-card__time {
  font-size: 30rpx;
  font-weight: 700;
  color: #263238;
}

.report-record-card__duration {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.report-record-card__status {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}

.report-record-card__tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.report-record-card__tag--excellent,
.report-record-card__tag--good {
  background: #eaf7e8;
  color: #3d8b32;
}

.report-record-card__tag--overtime {
  background: #fff7e6;
  color: #d97706;
}

.report-record-card__tag--risk {
  background: #ffecec;
  color: #dc2626;
}

.report-record-card__sub {
  font-size: 22rpx;
  color: #6b7280;
}

.report-record-card__remind {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.report-record-card__action {
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  font-size: 22rpx;
  color: #58b947;
  white-space: nowrap;
}

.report-record-card__arrow {
  margin-top: 8rpx;
  font-size: 36rpx;
  line-height: 1;
}
