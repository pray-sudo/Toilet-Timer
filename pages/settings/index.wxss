.settings-page {
  padding-top: 24rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.settings-header {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.settings-header__title {
  font-size: 40rpx;
  font-weight: 700;
  color: #263238;
}

.settings-header__desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
}

.settings-section {
  padding: 8rpx 32rpx 24rpx;
  margin-bottom: 24rpx;
}

.settings-section__title {
  padding: 20rpx 0 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #263238;
}

.style-setting {
  padding: 28rpx 0 8rpx;
}

.style-setting__label {
  font-size: 30rpx;
  font-weight: 600;
  color: #263238;
}

.style-setting__desc {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 6rpx;
  line-height: 1.5;
}

.style-setting__options {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.style-setting__option {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 28rpx;
}

.style-setting__option--active {
  background: #eaf7e8;
  color: #3d8b32;
  font-weight: 600;
}

.clear-data {
  padding: 24rpx 0 8rpx;
}

.clear-data__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #e5484d;
}

.clear-data__desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
}

.settings-footer {
  padding: 8rpx 8rpx 24rpx;
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.7;
  text-align: center;
}

.settings-footer__sub {
  margin-top: 12rpx;
}
