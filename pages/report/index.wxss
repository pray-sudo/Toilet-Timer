.report-page {
  padding-top: 24rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.report-header {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.report-header__title {
  font-size: 40rpx;
  font-weight: 700;
  color: #263238;
}

.report-header__tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.report-stats {
  margin-bottom: 8rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.report-list {
  margin-top: 8rpx;
}

.report-empty {
  padding: 48rpx 32rpx 40rpx;
  text-align: center;
  margin-top: 8rpx;
}

.report-empty__icon {
  font-size: 72rpx;
  line-height: 1;
}

.report-empty__title {
  margin-top: 20rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #263238;
}

.report-empty__desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
}

.report-empty__action {
  margin-top: 32rpx;
}
