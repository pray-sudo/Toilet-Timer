<view class="profile-page page-container">
  <view class="profile-header card">
    <view class="profile-header__avatar">🛡️</view>
    <view class="profile-header__info">
      <view class="profile-header__name">健康守护者</view>
      <view class="profile-header__desc">肛好，才是真的好</view>
    </view>
  </view>

  <view class="menu card">
    <view class="menu-item" bindtap="handleOpenBadges">
      <view class="menu-item__left">
        <text class="menu-item__icon">🏅</text>
        <text class="menu-item__title">我的勋章</text>
      </view>
      <text class="menu-item__arrow">›</text>
    </view>
    <view class="menu-item" bindtap="handleOpenSettings">
      <view class="menu-item__left">
        <text class="menu-item__icon">⚙️</text>
        <text class="menu-item__title">设置</text>
      </view>
      <text class="menu-item__arrow">›</text>
    </view>
    <view class="menu-item" bindtap="handleOpenPrivacy">
      <view class="menu-item__left">
        <text class="menu-item__icon">🔒</text>
        <text class="menu-item__title">隐私政策</text>
      </view>
      <text class="menu-item__arrow">›</text>
    </view>
    <view class="menu-item" bindtap="handleOpenAgreement">
      <view class="menu-item__left">
        <text class="menu-item__icon">📄</text>
        <text class="menu-item__title">用户协议</text>
      </view>
      <text class="menu-item__arrow">›</text>
    </view>
    <view class="menu-item menu-item--last" bindtap="handleOpenAbout">
      <view class="menu-item__left">
        <text class="menu-item__icon">💚</text>
        <text class="menu-item__title">关于产品</text>
      </view>
      <text class="menu-item__arrow">›</text>
    </view>
  </view>

  <view class="profile-tip">
    可在设置中调整提醒方式，或清空本地守护记录
  </view>
</view>
