.trend-page {
  padding-top: 24rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.page-intro {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.page-intro__title {
  font-size: 36rpx;
  font-weight: 700;
  color: #263238;
}

.page-intro__desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
}

.trend-stats {
  margin-bottom: 24rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

/* ---- 图表区域 ---- */
.trend-chart {
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
}

.chart-area {
  display: flex;
  margin-top: 24rpx;
  height: 320rpx;
}

.chart-y-axis {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: flex-end;
  padding-right: 12rpx;
  width: 80rpx;
  flex-shrink: 0;
  padding-bottom: 48rpx;
}

.chart-y-label {
  font-size: 20rpx;
  color: #9ca3af;
}

.chart-bars-wrap {
  flex: 1;
  min-width: 0;
  border-left: 1rpx solid #e5e7eb;
  border-bottom: 1rpx solid #e5e7eb;
  padding-bottom: 48rpx;
  position: relative;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 100%;
  padding: 0 8rpx;
}

.chart-bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  min-width: 0;
  height: 100%;
  position: relative;
}

.chart-bar-value {
  font-size: 18rpx;
  color: #6b7280;
  margin-bottom: 4rpx;
  white-space: nowrap;
}

.chart-bar {
  width: 36rpx;
  border-radius: 6rpx 6rpx 0 0;
  min-height: 4rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  transition: height 0.3s ease;
  position: relative;
}

.chart-bar--today {
  width: 42rpx;
}

.chart-bar-count {
  position: absolute;
  bottom: 4rpx;
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.9);
  white-space: nowrap;
}

.chart-bar-label {
  position: absolute;
  bottom: -44rpx;
  font-size: 20rpx;
  color: #9ca3af;
  white-space: nowrap;
}

.chart-bar-label--today {
  color: #58b947;
  font-weight: 700;
}

/* ---- 风险提示 ---- */
.trend-risk-tip {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  background: #fff7e6;
  border-radius: 16rpx;
}

.trend-risk-tip__icon {
  font-size: 36rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.trend-risk-tip__text {
  font-size: 24rpx;
  color: #d97706;
  line-height: 1.6;
}

/* ---- 厕所成长 ---- */
.trend-toilet { padding: 32rpx; margin-bottom: 24rpx; }
.toilet-level-badge { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.toilet-level-stars { font-size: 32rpx; font-weight: 700; color: #c8a030; }
.toilet-level-name { font-size: 28rpx; font-weight: 600; color: #5a4a20; }
.toilet-progress-bar { height: 16rpx; background: #f0eee0; border-radius: 8rpx; overflow: hidden; margin-bottom: 12rpx; }
.toilet-progress-bar__fill { height: 100%; background: linear-gradient(90deg, #58b947, #c8a030); border-radius: 8rpx; transition: width 0.4s ease; }
.toilet-progress-info { font-size: 22rpx; color: #888; margin-bottom: 20rpx; }

.trend-empty {
  padding: 56rpx 32rpx 40rpx;
  text-align: center;
}

.trend-empty__icon {
  font-size: 72rpx;
  line-height: 1;
}

.trend-empty__title {
  margin-top: 20rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #263238;
}

.trend-empty__desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
}

.trend-empty__action {
  margin-top: 32rpx;
}
