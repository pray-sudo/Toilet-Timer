/* ===== 页面根 ===== */
page {
  width: 100%;
  height: 100%;
  background: #f4faee;
}

.home-page {
  position: relative;
  width: 100%;
  height: 100vh;
  min-height: 100vh;
  overflow: hidden;
  background: linear-gradient(
    180deg,
    #f8fcf2 0%,
    #f2faea 24%,
    #e6f4d7 52%,
    #d7edc2 76%,
    #cbe8b2 100%
  );
}

/* ===== 背景图片层 ===== */
.home-bg-image-layer {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}

.home-bg-img {
  position: absolute;
  display: block;
  pointer-events: none;
}

.home-bg-top-air {
  left: 0;
  top: 0;
  width: 100%;
  opacity: 0.86;
}

.home-bg-hero-support {
  left: 0;
  top: 18vh;
  width: 100%;
  max-height: 50vh;
  opacity: 0.78;
}

.home-bg-side-plants {
  left: 0;
  top: 24vh;
  width: 100%;
  max-height: 45vh;
  opacity: 0.72;
}

.home-bg-ground-scene {
  left: 0;
  bottom: 0;
  width: 100%;
  opacity: 0.92;
}

/* --- 短屏适配（iPhone SE / 6 / 7 / 8） --- */
@media screen and (max-height: 667px) {
  .home-bg-hero-support {
    top: 15vh;
    opacity: 0.68;
  }

  .home-bg-side-plants {
    top: 28vh;
    opacity: 0.58;
  }

  .home-bg-ground-scene {
    bottom: -70rpx;
    opacity: 0.82;
  }
}

/* --- 长屏适配（iPhone Pro Max / 大屏） --- */
@media screen and (min-height: 780px) {
  .home-bg-hero-support {
    top: 20vh;
    opacity: 0.82;
  }

  .home-bg-side-plants {
    top: 25vh;
    opacity: 0.78;
  }

  .home-bg-ground-scene {
    bottom: 0;
    opacity: 1;
  }
}

