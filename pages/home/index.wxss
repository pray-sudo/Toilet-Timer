/* ===== 主内容层 ===== */
.main-layout {
  position: relative;
  z-index: 10;
  height: calc(100vh - 250rpx);
  padding-top: 96rpx;
  padding-left: 32rpx;
  padding-right: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

/* ---- 顶部标题 ---- */
.top-section {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.home-title {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 44rpx;
  color: #2f3d32;
  letter-spacing: 1rpx;
}

/* ===== 视觉主体组 ===== */
.visual-action-group {
  flex: 1;
  width: 100%;
  min-height: 760rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: -20rpx;
}

/* ---- 气泡 ---- */
.care-bubble {
  position: relative;
  min-width: 300rpx;
  max-width: 520rpx;
  height: 68rpx;
  padding: 0 38rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(240, 255, 230, 0.92) 100%);
  box-shadow:
    0 6rpx 20rpx rgba(92, 168, 70, 0.14),
    inset 0 1rpx 0 rgba(255, 255, 255, 1);
  border: 1rpx solid rgba(180, 220, 160, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.care-bubble-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #4a7a3e;
  line-height: 68rpx;
  white-space: nowrap;
}

.care-bubble-tail {
  position: absolute;
  bottom: -7rpx;
  left: 50%;
  margin-left: -8rpx;
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 8rpx solid rgba(245, 255, 238, 0.94);
}

/* ---- 吉祥物 ---- */
.mascot {
  width: 540rpx;
  max-width: 540rpx;
  display: block;
  margin-bottom: 18rpx;
}

/* ---- 按钮 ---- */
.start-btn {
  width: 580rpx;
  max-width: 82vw;
  min-width: 500rpx;
  height: auto;
  margin-top: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.14s ease, opacity 0.14s ease;
}

.start-btn-img {
  width: 100%;
  display: block;
  pointer-events: none;
}

.start-btn--hover {
  transform: scale(0.965) translateY(2rpx);
  opacity: 0.92;
}

/* ---- 按钮：短屏适配 ---- */
@media screen and (max-height: 667px) {
  .start-btn {
    width: 520rpx;
    margin-top: -4rpx;
  }
}

/* ---- 按钮：长屏适配 ---- */
@media screen and (min-height: 780px) {
  .start-btn {
    width: 600rpx;
  }
}

/* ---- 推荐时长 ---- */
.time-tip {
  margin-top: 12rpx;
  height: 48rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.time-tip-info {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
  border-radius: 50%;
  border: 2rpx solid #6a9a58;
  font-size: 15rpx;
  font-weight: 700;
  font-style: italic;
  color: #6a9a58;
  opacity: 0.75;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  flex-shrink: 0;
}

.time-tip-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #4a7a3e;
  line-height: 48rpx;
}

/* ===== 底部入口层 ===== */
.bottom-entry-area {
  position: absolute;
  left: 0;
  right: 0;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  z-index: 20;
  display: flex;
  align-items: stretch;
  justify-content: center;
  gap: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.entry-card {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  overflow: hidden;
  transition: opacity 0.14s ease;
}

.entry-card--hover {
  opacity: 0.88;
}

.entry-card-img {
  width: 100%;
  display: block;
  pointer-events: none;
}

/* --- 底部卡片：短屏适配 --- */
@media screen and (max-height: 667px) {
  .bottom-entry-area {
    bottom: calc(20rpx + env(safe-area-inset-bottom));
    padding: 0 20rpx;
    gap: 12rpx;
  }
}

/* --- 底部卡片：长屏适配 --- */
@media screen and (min-height: 780px) {
  .bottom-entry-area {
    bottom: calc(34rpx + env(safe-area-inset-bottom));
    padding: 0 26rpx;
    gap: 18rpx;
  }
}

/* ===== 时间选择弹窗 ===== */
.time-modal-mask {
  position: fixed;
  inset: 0;
  z-index: 1000;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.time-modal {
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
}

.time-modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  text-align: center;
  margin-bottom: 8rpx;
}

/* 守护方式选择 */
.mode-section {
  margin-bottom: 4rpx;
}

.mode-label {
  font-size: 24rpx;
  color: #888;
  margin-top: 24rpx;
  margin-bottom: 16rpx;
}

.mode-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mode-option {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #f5f7f0;
  border: 2rpx solid transparent;
  position: relative;
  transition: all 0.15s;
}

.mode-option--active {
  background: #eef7e6;
  border-color: #58b947;
}

.mode-option-icon {
  font-size: 40rpx;
  line-height: 1;
  flex-shrink: 0;
}

.mode-option-text {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.mode-option-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.mode-option--active .mode-option-name {
  color: #3d8b32;
}

.mode-option-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.mode-option--active .mode-option-desc {
  color: #6aaa58;
}

.mode-option-tag {
  font-size: 18rpx;
  color: #fff;
  background: #58b947;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  line-height: 1.4;
  flex-shrink: 0;
}

.time-modal-options {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.time-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  border-radius: 20rpx;
  background: #f5f7f0;
  border: 2rpx solid transparent;
  position: relative;
}

.time-option--active {
  background: #eef7e6;
  border-color: #58b947;
}

.time-option-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
  line-height: 1.2;
}

.time-option--active .time-option-num {
  color: #3d8b32;
}

.time-option-unit {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.time-option--active .time-option-unit {
  color: #58b947;
}

.time-option-tag {
  position: absolute;
  top: -1rpx;
  right: -1rpx;
  font-size: 18rpx;
  color: #fff;
  background: #58b947;
  padding: 2rpx 12rpx;
  border-radius: 0 18rpx 0 12rpx;
  line-height: 1.5;
}

.time-modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.time-modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}

.time-modal-btn--cancel {
  background: #f2f2f2;
  color: #666;
}

.time-modal-btn--confirm {
  background: linear-gradient(135deg, #6cc258 0%, #4a9e3c 100%);
  color: #fff;
}
