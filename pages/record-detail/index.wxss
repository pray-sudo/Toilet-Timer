.record-detail {
  padding-top: 24rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.result-card {
  padding: 40rpx 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.result-card--excellent,
.result-card--good {
  border-top: 8rpx solid #58b947;
}

.result-card--overtime {
  border-top: 8rpx solid #f59e0b;
}

.result-card--risk {
  border-top: 8rpx solid #e5484d;
}

.result-card__label {
  font-size: 40rpx;
  font-weight: 700;
  color: #263238;
}

.result-card__duration {
  margin-top: 12rpx;
  font-size: 30rpx;
  color: #6b7280;
}

.result-card__desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #263238;
  line-height: 1.6;
}

.result-card__badge {
  display: inline-block;
  margin-top: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: #eaf7e8;
  color: #3d8b32;
  font-size: 22rpx;
}

.info-card,
.advice-card {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row__label {
  font-size: 26rpx;
  color: #6b7280;
  flex-shrink: 0;
}

.info-row__value {
  font-size: 26rpx;
  color: #263238;
  text-align: right;
  line-height: 1.5;
}

.advice-card__text {
  font-size: 26rpx;
  color: #263238;
  line-height: 1.7;
}

.advice-card__note {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.6;
}

.info-row__value--exp { color: #58b947; font-weight: 600; }
.info-row__value--level { color: #c8a030; font-weight: 600; }
.info-row--upgrade { justify-content: center; padding: 12rpx 0; border-bottom: none; }
.info-row__value--upgrade { color: #e8a020; font-weight: 700; font-size: 28rpx; }

.record-detail__action {
  margin-top: 8rpx;
}
