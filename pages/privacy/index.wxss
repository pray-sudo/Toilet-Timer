.legal-page {
  padding-top: 24rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.legal-card {
  padding: 32rpx;
}

.legal-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #263238;
  margin-bottom: 24rpx;
}

.legal-section {
  margin-bottom: 28rpx;
}

.legal-section__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #263238;
  margin-bottom: 10rpx;
}

.legal-section__text {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.7;
}
